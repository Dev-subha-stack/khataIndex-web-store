rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only allow admin SDK (server-side) to read/write by default, or define secure fallback client rules.
    match /users/{userId} {
      allow read, write: if false; // Server only
    }
    match /versions/{versionId} {
      allow read: if true; // Public versions listing
      allow write: if false; // Server only
    }
    match /tokens/{tokenId} {
      allow read, write: if false; // Server only
    }
  }
}
